{
  "buildCommand": "bash build.sh",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/app",
      "destination": "/app.html"
    },
    {
      "source": "/app/:path*",
      "destination": "/app.html"
    },
    {
      "source": "/forfaits",
      "destination": "/forfaits.html"
    },
    {
      "source": "/services",
      "destination": "/services.html"
    },
    {
      "source": "/service-vip",
      "destination": "/service-vip.html"
    },
    {
      "source": "/rejoindre",
      "destination": "/rejoindre.html"
    },
    {
      "source": "/fournisseurs",
      "destination": "/fournisseurs.html"
    }
  ]
}
