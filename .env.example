# ==============================================================================
# Kadio Salon Management App - Environment Variables Example
# ==============================================================================
# Copier ce fichier en .env.local et remplir les valeurs pour votre environnement
# Copy this file to .env.local and fill in the values for your environment

# ==============================================================================
# SUPABASE - Authentication, Database, Storage
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==============================================================================
# STRIPE - Payments, Subscriptions, Partner Payouts
# ==============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CONNECT_ACCOUNT_ID=acct_xxx

# ==============================================================================
# SQUARE - In-Person Payments, Gift Cards
# ==============================================================================
SQUARE_ACCESS_TOKEN=sq_xxx
SQUARE_LOCATION_ID=loc_xxx
SQUARE_APPLICATION_ID=app_xxx

# ==============================================================================
# TWILIO - SMS: OTP, Reminders, Campaigns
# ==============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=auth_token_xxx
TWILIO_PHONE_NUMBER=+1234567890

# ==============================================================================
# GOOGLE MAPS - Optional (OSM utilisé par défaut / OSM used by default)
# ==============================================================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================================================
# FIREBASE - Push Notifications (FCM via Web Push API)
# ==============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# VAPID key for Web Push (generate via Firebase Cloud Messaging settings)
# Used by service worker to subscribe to push notifications
VITE_FIREBASE_VAPID_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================================================
# VERCEL - Deployment
# ==============================================================================
NEXT_PUBLIC_VERCEL_URL=https://kadio.vercel.app

# ==============================================================================
# APP CONFIGURATION - Feature Flags
# ==============================================================================
# Use real authentication (false = mock OTP for testing)
USE_REAL_AUTH=false

# Use real SMS service (false = console logging for testing)
USE_REAL_SMS=false

# Use real payment processing (false = test/mock mode)
USE_REAL_PAYMENTS=false

# ==============================================================================
# OPTIONAL - Additional Configuration
# ==============================================================================
# Node environment
NODE_ENV=development

# API Base URL
NEXT_PUBLIC_API_URL=http://localhost:3000
